{
  "manifest_version": 3,
  "name": "Extinction",
  "description": "An ultra-lightweight AI content blocker extension.",
  "version": "0.0.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "{{firefox}}.browser_specific_settings": {
    "gecko": {
      "id": "@extinction.v81d",
      "data_collection_permissions": {
        "required": ["websiteContent"]
      }
    },
    "gecko_android": {}
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "background": {
    "{{chrome}}.service_worker": "src/background.js",
    "{{chrome}}.type": "module",
    "{{firefox}}.scripts": ["src/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"],
      "run_at": "document_end"
    }
  ]
}
